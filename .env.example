# ════════════════════════════════════════════════════════════════════
# ALihas Environment Configuration
# IMPORTANTE: Copiar todas estas variables en la pestaña 'Environment'
# de tu despliegue en Dokploy o en un archivo .env si usas local.
# ════════════════════════════════════════════════════════════════════

# 1. LA JAULA: CAPA DE SEGURIDAD NEMOCLAW (OPEN_SHELL)
NEMOCLAW_SECURITY_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_API_KEY=tu_api_key_de_nvidia

# 2. EL CEREBRO ACTIVO: ENRUTAMIENTO DINÁMICO (JOSEIAS)
ACTIVE_API_KEY=tu_api_key_principal_aqui
ACTIVE_BASE_URL=https://api.openai.com/v1
ACTIVE_MODEL=gpt-4o

# 3. BÓVEDA DE APIS MULTI-PROVEEDOR
GEMINI_API_KEY=tu_api_key_gemini
OPENROUTER_API_KEY=tu_api_key_openrouter
ANTHROPIC_API_KEY=tu_api_key_anthropic
ZAI_API_KEY=tu_api_key_zai
MINIMAX_API_KEY=tu_api_key_minimax
MOONSHOT_API_KEY=tu_api_key_moonshot
GROQ_API_KEY=tu_api_key_groq
XAI_API_KEY=tu_api_key_xai
MISTRAL_API_KEY=tu_api_key_mistral
QWEN_API_KEY=tu_api_key_dashscope
CLOUDFLARE_API_KEY=tu_api_key_cloudflare
CLOUDFLARE_ACCOUNT_ID=tu_account_id_cloudflare

# 4. SISTEMA Y CONFIGURACIÓN BASE
AUTH_USERNAME=admin
AUTH_PASSWORD=tu_password_seguro
OPENCLAW_GATEWAY_TOKEN=tu_token_de_gateway
TELEGRAM_BOT_TOKEN=tu_token_de_telegram
HOOKS_TOKEN=tu_token_de_hooks
